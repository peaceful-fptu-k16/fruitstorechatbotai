# Backend
DATABASE_URL=sqlite:///./backend/data/fruit_chatbot.db
ADMIN_JWT_SECRET=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
CORS_ORIGINS=["*"]
ALLOW_REMOTE_MODEL_DOWNLOAD=true
USE_PRETRAINED_INTENT_ROUTER=true
PRETRAINED_INTENT_ROUTER_BACKEND=zero_shot
PRETRAINED_INTENT_MODEL_NAME=BAAI/bge-m3
PRETRAINED_INTENT_ZERO_SHOT_MODEL_NAME=joeddav/xlm-roberta-large-xnli
PRETRAINED_INTENT_MIN_CONFIDENCE=0.55
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL_NAME=BAAI/bge-m3
USE_PRETRAINED_RERANKER=true
PRETRAINED_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_CANDIDATE_POOL=30
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL_NAME=
LM_STUDIO_TIMEOUT_SECONDS=15.0
LM_STUDIO_TEMPERATURE=0.2
ENABLE_USER_QUERY_LOGGING=true
USER_QUERY_LOG_PATH=ai_log/user_questions.jsonl
ENABLE_QA_PAIR_LOGGING=true
QA_PAIR_LOG_PATH=ai_log/qa_pairs.jsonl

# Facebook Messenger chatbot service
FACEBOOK_VERIFY_TOKEN=change-me-facebook-verify-token
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=me
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v22.0
FACEBOOK_REQUEST_TIMEOUT_SECONDS=8.0
# Optional override for Messenger product card images. Leave empty to use current fruit logos.
# Supports public HTTPS patterns with {id} and {slug}.
FACEBOOK_PRODUCT_IMAGE_BASE_URL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
